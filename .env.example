NEXT_PUBLIC_API_URL=https://sellai-production.up.railway.app

# Sentry — leave blank to disable.
# Browser DSN (safe to expose).
NEXT_PUBLIC_SENTRY_DSN=
# Optional override on the server (defaults to NEXT_PUBLIC_SENTRY_DSN).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production
NEXT_PUBLIC_SENTRY_RELEASE=sellai-admin@0.1.0
# For source-map upload at build time. Leave SENTRY_ORG empty to skip uploads.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
